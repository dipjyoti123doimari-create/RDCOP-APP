# ─────────────────────────────────────────────────────────────────
# .env.example  —  copy this to .env and fill in the real values
# ─────────────────────────────────────────────────────────────────
# IMPORTANT: .env is listed in .gitignore — NEVER commit .env to git.

# Flask session secret key (change this to a long random string in production)
SECRET_KEY=change-me-to-a-long-random-secret-key

# ── Initial SUPER_ADMIN account ───────────────────────────────────
# Created automatically on first startup if no users exist in the DB.
# After the first login, manage all users through the /admin/users page.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_EMAIL=admin@rdc.local

# ── SMTP (for sending report emails) ─────────────────────────────
# These are configured via the app UI (Settings → SMTP) and stored in the DB.
# You can also pre-seed them here if you prefer:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_gmail_app_password

# ── Oracle (for production data fetching) ────────────────────────
# These are configured via the app UI (Settings → Oracle) and stored in the DB.
# ORACLE_DSN=your_oracle_dsn
# ORACLE_USER=your_oracle_username
# ORACLE_PASS=your_oracle_password
